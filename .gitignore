# ============================================
# EXCEPCIÓN: conservar .gitkeep para estructura
# ============================================
!**/.gitkeep

# ============================================
# PYTHON
# ============================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

