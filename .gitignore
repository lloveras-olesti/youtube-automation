# Aportar el propio — ver README
# ============================================
data/input/recursos/referencia.wav

# ============================================
# DATOS RUNTIME (analytics reales del canal)
# ============================================
runtime/

# ============================================
# ASSETS MULTIMEDIA DE INPUT
# Aportar los propios según estructura indicada en README
# ============================================
data/input/recursos/musica/*
data/input/recursos/portadas/ARQUERO/*
data/input/recursos/portadas/CADENAS/*
data/input/recursos/portadas/CÁLIZ/*
data/input/recursos/portadas/CRUZ/*
data/input/recursos/portadas/DEMONIO/*
