data/input/recursos/portadas/FENIX/*
data/input/recursos/portadas/JESUS/*
data/input/recursos/portadas/LEON/*
data/input/recursos/portadas/LIBRO/*
data/input/recursos/videos-loop/foto1/*
data/input/recursos/videos-loop/foto2/*
data/input/recursos/videos-loop/foto3/*
data/input/recursos/videos-loop/foto4/*
data/input/recursos/videos-loop/foto5/*

# ============================================
# DIRECTORIOS DE OUTPUT Y TEMPORALES
# ============================================
data/logs/*.log
data/logs/aprendizaje/*
data/logs/calendario/*
data/logs/pipeline/*
data/logs/portadas/*
data/logs/referencias/*
