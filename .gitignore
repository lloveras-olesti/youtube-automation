# ============================================
# SECRETOS Y CREDENCIALES
# ============================================
.env
config/youtube_client_secrets.json
data/youtube_token.json

# ============================================
# ENTORNO TTS LOCAL (host Windows)
# 9.4 GB — recrear según README
# ============================================
tts-venv/
tts-model/

