# ============================================
# CONFIGURACIÓN DEL PROYECTO CANAL RELI
# Ubicación: .env.example
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Rellena tus valores reales
# 3. NUNCA commitees el archivo .env
# ============================================

# ============================================
# APIS EXTERNAS
# ============================================

# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 — https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================
# CONFIGURACIÓN DEL CANAL
# ============================================

# URL del canal de YouTube
CANAL_URL=https://www.youtube.com/channel/YOUR_CHANNEL_ID?sub_confirmation=1

# ============================================
# CONFIGURACIÓN DE GENERACIÓN
# ============================================

SCRIPT_LENGTH=5000

# ============================================
# CONFIGURACIÓN DE VIDEO
# ============================================

VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30

# ============================================
# CONFIGURACIÓN DE CLAUDE API
# ============================================

CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8000
CLAUDE_TEMPERATURE=0.7

# ============================================
# CONFIGURACIÓN DE WHISPER
# ============================================

WHISPER_MODEL_SIZE=small
WHISPER_LANGUAGE=es

# ============================================
# CONFIGURACIÓN GENERAL
# ============================================

LOG_LEVEL=INFO
PROJECT_NAME=canal-reli

# ============================================
# PATHS (no cambiar)
# ============================================

DATA_PATH=/app/data
PROMPTS_PATH=/app/prompts
SHARED_PROMPTS_PATH=/app/shared_prompts
